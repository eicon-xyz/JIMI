# 复制此文件为 .env 并填入真实值

# ── LLM API（推荐：SiliconCloud Qwen3.6，支持多模态看图）──
LLM_API_KEY=sk-your-siliconcloud-key-here
LLM_MODEL=Qwen/Qwen3.6-35B-A3B
LLM_BASE_URL=https://api.siliconflow.cn/v1
LLM_TIMEOUT=60

# ── DeepSeek API（兼容保留，LLM_* 未配置时 fallback）──
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT=30

# ── 服务认证 ──
HAJIMI_DEMO_KEY=hajimi-demo-2026
HAJIMI_HOST=0.0.0.0
HAJIMI_PORT=8010
HAJIMI_DEBUG=true

# ── Demo 开关 ──
USE_REAL_LLM=true
STRICT_FINGERPRINT=false

# ── OmniParser 视觉检测（本地 CPU 默认 :8002；校园 GPU 可改为 http://127.0.0.1:9800）──
OMNIPARSER_URL=http://127.0.0.1:8002
OMNIPARSER_TIMEOUT=360

# ── SetFit 意图分类模型路径 ──
INTENT_MODEL_PATH=server/services/intent/model
